{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-datafactory-aditi"
		},
		"LinkedserviceDL_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LinkedserviceDL'"
		},
		"LinkedserviceDL_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azurefundastorageaditi.dfs.core.windows.net/"
		},
		"source_git_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"pipeline1trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/f56673ef-12b9-4354-bfc2-2a7537ab05aa/resourceGroups/Azure_fundamentals/providers/Microsoft.Storage/storageAccounts/azurefundastorageaditi"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-datafactory-aditi_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LinkedserviceDL_accountKey": {
						"value": "[parameters('LinkedserviceDL_accountKey')]"
					},
					"LinkedserviceDL_properties_typeProperties_url": {
						"value": "[parameters('LinkedserviceDL_properties_typeProperties_url')]"
					},
					"source_git_properties_typeProperties_url": {
						"value": "[parameters('source_git_properties_typeProperties_url')]"
					},
					"pipeline1trigger_properties_typeProperties_scope": {
						"value": "[parameters('pipeline1trigger_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}